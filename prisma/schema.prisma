generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String         @id @default(uuid())
  authUserId       String         @unique @map("auth_user_id")
  email            String         @unique
  firstName        String         @map("first_name")
  lastName         String         @map("last_name")
  phone            String?
  licenseNumber    String?        @map("license_number")
  role             Role           @default(AGENT)
  status           AccountStatus  @default(PENDING_VALIDATION)
  realEstateId     String?        @map("real_estate_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  clients          Client[]
  events           Event[]
  sentMatches      Match[]        @relation("MatchRequester")
  memberships      Membership[]
  notifications    Notification[]
  properties       Property[]
  ownedRealEstates RealEstate[]   @relation("RealEstateOwner")
  realEstate       RealEstate?    @relation(fields: [realEstateId], references: [id])

  @@index([realEstateId])
  @@map("users")
}

model RealEstate {
  id                  String        @id @default(uuid())
  name                String
  phone               String
  address             String
  neighborhood        String?
  city                String
  professionalLicense String?       @map("professional_license")
  status              AccountStatus @default(PENDING_VALIDATION)
  membershipExpiresAt DateTime?     @map("membership_expires_at")
  internalNotes       String?       @map("internal_notes")
  ownerId             String?       @map("owner_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  clients             Client[]
  events              Event[]
  memberships         Membership[]
  properties          Property[]
  owner               User?         @relation("RealEstateOwner", fields: [ownerId], references: [id])
  users               User[]

  @@index([status])
  @@map("real_estates")
}

model Event {
  id           String     @id @default(uuid())
  title        String
  description  String?
  date         DateTime
  type         EventType
  userId       String     @map("user_id")
  realEstateId String     @map("real_estate_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  realEstate   RealEstate @relation(fields: [realEstateId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([userId])
  @@index([realEstateId])
  @@map("events")
}

model Property {
  id               String          @id @default(uuid())
  realEstateId     String          @map("real_estate_id")
  createdById      String          @map("created_by_id")
  cadastralId      String          @unique @map("cadastral_id")
  title            String
  type             PropertyType
  status           PropertyStatus  @default(ACTIVE)
  price            Decimal         @db.Decimal(12, 2)
  currency         String          @default("USD")
  address          String
  addressHash      String          @map("address_hash")
  province         String?
  department       String?
  city             String
  neighborhood     String?
  latitude         Decimal?        @db.Decimal(10, 7)
  longitude        Decimal?        @db.Decimal(10, 7)
  description      String?
  documentation    String?
  financing        Boolean         @default(false)
  financingPercent Int?            @map("financing_percent")
  acceptsTrade     Boolean         @default(false) @map("accepts_trade")
  tradePercent     Int?            @map("trade_percent")
  services         Json            @default("{}")
  features         Json            @default("{}")
  fieldFeatures    Json            @default("{}") @map("field_features")
  quality          Json            @default("{}")
  rejectionCount90 Int             @default(0) @map("rejection_count_90")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  matches          Match[]
  createdBy        User            @relation(fields: [createdById], references: [id])
  realEstate       RealEstate      @relation(fields: [realEstateId], references: [id], onDelete: Cascade)
  images           PropertyImage[]

  @@unique([addressHash, status])
  @@index([realEstateId, type, status])
  @@index([price])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  path       String
  publicUrl  String   @map("public_url")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Client {
  id                   String         @id @default(uuid())
  realEstateId         String         @map("real_estate_id")
  createdById          String         @map("created_by_id")
  firstName            String         @map("first_name")
  lastName             String         @map("last_name")
  phone                String?
  email                String?
  status               ClientStatus   @default(ACTIVE)
  minBudget            Decimal        @map("min_budget") @db.Decimal(12, 2)
  maxBudget            Decimal        @map("max_budget") @db.Decimal(12, 2)
  currency             String         @default("USD")
  desiredTypes         PropertyType[] @map("desired_types")
  desiredCities        String[]       @map("desired_cities")
  desiredNeighborhoods String[]       @default([]) @map("desired_neighborhoods")
  financingNeeded      Boolean        @default(false) @map("financing_needed")
  financingPercent     Int?           @map("financing_percent")
  hasTrade             Boolean        @default(false) @map("has_trade")
  tradePercent         Int?           @map("trade_percent")
  needsCredit          Boolean        @default(false) @map("needs_credit")
  requirements         Json           @default("{}")
  fieldRequirements    Json           @default("{}") @map("field_requirements")
  minMatchThreshold    Int            @default(70) @map("min_match_threshold")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  createdBy            User           @relation(fields: [createdById], references: [id])
  realEstate           RealEstate     @relation(fields: [realEstateId], references: [id], onDelete: Cascade)
  matches              Match[]

  @@index([realEstateId, status])
  @@index([maxBudget])
  @@map("clients")
}

model Match {
  id                   String      @id @default(uuid())
  clientId             String      @map("client_id")
  propertyId           String      @map("property_id")
  requesterId          String?     @map("requester_id")
  score                Int
  differences          Json        @default("[]")
  exclusions           Json        @default("[]")
  status               MatchStatus @default(PROPOSED)
  commissionAcceptedAt DateTime?   @map("commission_accepted_at")
  contactOpenedAt      DateTime?   @map("contact_opened_at")
  followUpAt           DateTime?   @map("follow_up_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  client               Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property             Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requester            User?       @relation("MatchRequester", fields: [requesterId], references: [id])

  @@unique([clientId, propertyId])
  @@index([status, score])
  @@map("matches")
}

model Notification {
  id           String           @id @default(uuid())
  userId       String?          @map("user_id")
  realEstateId String?          @map("real_estate_id")
  type         NotificationType
  title        String
  body         String
  metadata     Json             @default("{}")
  readAt       DateTime?        @map("read_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  user         User?            @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([realEstateId])
  @@map("notifications")
}

model Membership {
  id           String     @id @default(uuid())
  realEstateId String     @map("real_estate_id")
  userId       String?    @map("user_id")
  plan         String     @default("BASE")
  activeUntil  DateTime   @map("active_until")
  seats        Int        @default(5)
  notes        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  realEstate   RealEstate @relation(fields: [realEstateId], references: [id], onDelete: Cascade)
  user         User?      @relation(fields: [userId], references: [id])

  @@index([realEstateId, activeUntil])
  @@map("memberships")
}

model Neighborhood {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  city      String
  name      String
  createdAt DateTime @default(now())

  @@unique([city, name])
  @@map("neighborhoods")
}

model Location {
  id         String   @id @default(uuid())

  province   String
  department String
  city       String

  createdAt  DateTime @default(now())

  @@unique([province, department, city])

  @@index([province])
  @@index([department])
  @@index([city])

  @@map("locations")
}

enum Role {
  SUPER_ADMIN
  ADMIN_REAL_ESTATE
  AGENT
}

enum AccountStatus {
  PENDING_VALIDATION
  ACTIVE
  IN_REVIEW
  SUSPENDED
}

enum PropertyType {
  CASA
  DEPARTAMENTO
  TERRENO
  CAMPO
  LOCAL
  OFICINA
  CABANA
  GALPON
}

enum PropertyStatus {
  ACTIVE
  PAUSED
  IN_REVIEW
  SOLD
  ARCHIVED
}

enum ClientStatus {
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

enum MatchStatus {
  PROPOSED
  WAITING_OTHER_SIDE
  CONTACT_OPENED
  REJECTED
  LATENT
  CLOSED
  CONFLICT
}

enum NotificationType {
  MATCH
  VALIDATION
  MEMBERSHIP
  STOCK_CLEANING
  CONFLICT
  FOLLOW_UP
  NEW_MATCH
}

enum EventType {
  CAPTACION
  VISITA
  RESERVA
  ESCRITURA
  REUNION
  LLAMADA
  TAREA
}
